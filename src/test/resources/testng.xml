<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Automation Suite"
       parallel="methods"
       thread-count="${threads}">

    <listeners>
        <listener class-name="com.company.automation.base.TestListener"/>
        <listener class-name="com.company.automation.base.TestListener"/>
        <listener class-name="com.company.automation.base.RetryListener"/>
    </listeners>

    <test name="UI Tests">

        <packages>
            <package name="com.company.automation.tests"/>
        </packages>
    </test>

</suite>